// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "wasm"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model Loan {
  id              Int      @id @default(autoincrement())
  partName        String
  model           String?
  brand           String?
  fromStore       String
  toStore         String
  employeeName    String
  loanDate        DateTime @default(now())
  expectedReturn  DateTime
  returnDate      DateTime?
}

model Employee {
  id      Int    @id @default(autoincrement())
  name    String @unique
  storeId Int?
}

model Store {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  logo  String?
}
